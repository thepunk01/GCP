# 可选：GCP 项目 ID。留空也能启动管理面板，进入面板后在 Profile 里填写。
GCP_PROJECT_ID=

# 默认创建实例的 zone
GCP_DEFAULT_ZONE=us-central1-a

# 生产环境强烈建议设置长随机 Token：openssl rand -hex 32
PANEL_TOKEN=change-me-to-a-long-random-token

# dev 环境允许不设置 PANEL_TOKEN；prod 必须设置
APP_ENV=prod

# 面板上传的 GCP Service Account JSON 默认保存位置
DATA_DIR=/data

# 可选：手动指定 Google 凭据路径
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa.json

# 可选：启用“换 IP 后自动更新 Cloudflare DNS”
# CF_API_TOKEN=your-cloudflare-api-token
